{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "core/**",
          "endpoints/**",
          "services/**",
          "models/**",
          "repository/**",
          "messages/**",
          "middlewares/**",
          "mock-models/**",
          "notification/**",
          "workers/**"
        ]
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api/index.js"
    }
  ]
}
